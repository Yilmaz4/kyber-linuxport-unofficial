# Build outputs - produced by tools/build-appimage.sh
# Covers the release build plus diagnostic/bugfix-test variants and .bak-*.
tools/KyberLinuxPort*.AppImage*
tools/KyberLinuxPort.AppDir/
tools/KyberLinuxPort.extracted/
# Update manifest for the self-updater; regenerated per build, uploaded as a
# release asset (not source).
tools/latest.json

# Sentry native crash-handler runtime data
.sentry-native/

# Diagnostic log exports (Logs Ubuntu/, Logs CachyOS/, ...)
Logs */

# Source tarballs produced for release uploads
tools/*-source.tar.gz

# Internal dev notes - not for distribution
notes/

# Top-level Maxima/ - separate clone of upstream Maxima used historically
# for source builds; not referenced by the AppImage build pipeline (which
# uses Kyber/{,CLI/}ThirdParty/Maxima/ via submodules).
Maxima/

# Backup directory created during pre-perf-fix snapshot
backups/

# OS / IDE cruft
.DS_Store
.idea/
*.iml
.vscode/

# Build / test artifacts
*.log
*.bak
.claude/
